<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<main class="main-content">
    <header style="margin-bottom: 2rem;">
        <h1 style="font-weight: 800; color: var(--secondary);">Dashboard</h1>
        <p style="color: var(--text-muted);">Bienvenido al Sistema de Gestión Académica del Instituto FORMAS.</p>
    </header>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
        <div class="data-card" style="padding: 1.5rem; border-left: 5px solid var(--primary); margin-top: 0;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <p style="color: var(--text-muted); font-size: 0.875rem; font-weight: 600;">ESTUDIANTES</p>
                    <h2 style="font-size: 2rem; margin: 0.5rem 0;"><%= stats.students %></h2>
                </div>
                <i class="fas fa-user-graduate" style="font-size: 2.5rem; color: #e2e8f0;"></i>
            </div>
        </div>

        <div class="data-card" style="padding: 1.5rem; border-left: 5px solid var(--success); margin-top: 0;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <p style="color: var(--text-muted); font-size: 0.875rem; font-weight: 600;">INSTRUCTORES</p>
                    <h2 style="font-size: 2rem; margin: 0.5rem 0;"><%= stats.instructors %></h2>
                </div>
                <i class="fas fa-chalkboard-teacher" style="font-size: 2.5rem; color: #e2e8f0;"></i>
            </div>
        </div>

        <div class="data-card" style="padding: 1.5rem; border-left: 5px solid var(--accent); margin-top: 0;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <p style="color: var(--text-muted); font-size: 0.875rem; font-weight: 600;">CURSOS</p>
                    <h2 style="font-size: 2rem; margin: 0.5rem 0;"><%= stats.courses %></h2>
                </div>
                <i class="fas fa-book" style="font-size: 2.5rem; color: #e2e8f0;"></i>
            </div>
        </div>

        <div class="data-card" style="padding: 1.5rem; border-left: 5px solid var(--warning); margin-top: 0;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <p style="color: var(--text-muted); font-size: 0.875rem; font-weight: 600;">GRUPOS</p>
                    <h2 style="font-size: 2rem; margin: 0.5rem 0;"><%= stats.groups %></h2>
                </div>
                <i class="fas fa-users" style="font-size: 2.5rem; color: #e2e8f0;"></i>
            </div>
        </div>
    </div>

    <div class="data-card" style="margin-top: 2rem; padding: 2rem;">
        <h3>Acciones Rápidas</h3>
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
            <a href="/students" class="btn btn-primary"><i class="fas fa-plus" style="margin-right: 0.5rem;"></i> Nuevo Estudiante</a>
            <a href="/enrollments" class="btn btn-primary" style="background-color: var(--success);"><i class="fas fa-user-plus" style="margin-right: 0.5rem;"></i> Matricular Estudiante</a>
            <a href="/grades" class="btn btn-primary" style="background-color: var(--accent);"><i class="fas fa-star" style="margin-right: 0.5rem;"></i> Registrar Notas</a>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
