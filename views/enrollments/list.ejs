<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="main-content">
    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="font-weight: 800; color: var(--secondary);">Gestión de Matrículas</h1>
            <p style="color: var(--text-muted);">Vincula estudiantes a los grupos disponibles.</p>
        </div>
        <button class="btn btn-primary" onclick="openModal('addModal')">
            <i class="fas fa-plus" style="margin-right: 0.5rem;"></i> Nueva Matrícula
        </button>
    </header>

    <% if (error) { %>
        <div class="alert alert-error">
            <i class="fas fa-exclamation-triangle"></i> <%= error %>
        </div>
    <% } %>

    <div class="data-card">
        <div class="table-header">
            <h3 style="font-size: 1.125rem;">Registro de Matrículas</h3>
        </div>
        <div style="overflow-x: auto;">
            <table>
                <thead>
                    <tr>
                        <th>Estudiante</th>
                        <th>Curso</th>
                        <th>Horario</th>
                        <th>Fecha Registro</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% enrollments.forEach(enroll => { %>
                        <tr>
                            <td style="font-weight: 600;"><%= enroll.student_nombres %> <%= enroll.student_apellidos %></td>
                            <td><%= enroll.curso_nombre %></td>
                            <td><%= enroll.horario %></td>
                            <td><%= new Date(enroll.fecha_matricula).toLocaleDateString() %></td>
                            <td>
                                <span class="badge" style="padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; background: <%= enroll.estado === 'registrada' ? '#dcfce7' : '#fee2e2' %>; color: <%= enroll.estado === 'registrada' ? '#15803d' : '#b91c1c' %>;">
                                    <%= enroll.estado.toUpperCase() %>
                                </span>
                            </td>
                            <td>
                                <% if (enroll.estado === 'registrada') { %>
                                    <a href="/enrollments/cancel/<%= enroll.id_matricula %>" class="btn" style="padding: 0.4rem; background: #f1f5f9; color: var(--error);" onclick="return confirm('¿Cancelar matrícula?')">
                                        <i class="fas fa-times-circle"></i> Cancelar
                                    </a>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<div id="addModal" class="modal-overlay">
    <div class="modal-content">
        <h3>Nueva Matrícula</h3>
        <form action="/enrollments/add" method="POST">
            <div class="form-group">
                <label class="form-label">Seleccionar Estudiante</label>
                <select name="id_estudiante" class="form-control" required>
                    <% students.forEach(student => { %>
                        <option value="<%= student.id_estudiante %>"><%= student.nombres %> <%= student.apellidos %> (<%= student.documento %>)</option>
                    <% }) %>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Seleccionar Grupo / Curso</label>
                <select name="id_grupo" class="form-control" required>
                    <% groups.forEach(group => { %>
                        <option value="<%= group.id_grupo %>"><%= group.curso_nombre %> - <%= group.horario %></option>
                    <% }) %>
                </select>
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
                <button type="button" class="btn" style="background: #e2e8f0;" onclick="closeModal('addModal')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Registrar Matrícula</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }
</script>

<%- include('../partials/footer') %>
