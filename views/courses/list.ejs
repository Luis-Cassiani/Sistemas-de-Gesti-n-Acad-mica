<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="main-content">
    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="font-weight: 800; color: var(--secondary);">Gestión de Cursos</h1>
            <p style="color: var(--text-muted);">Administra la oferta académica del instituto.</p>
        </div>
        <button class="btn btn-primary" onclick="openModal('addModal')">
            <i class="fas fa-plus" style="margin-right: 0.5rem;"></i> Nuevo Curso
        </button>
    </header>

    <div class="data-card">
        <div class="table-header">
            <h3 style="font-size: 1.125rem;">Lista de Cursos</h3>
        </div>
        <div style="overflow-x: auto;">
            <table>
                <thead>
                    <tr>
                        <th>Nombre del Curso</th>
                        <th>Duración (Horas)</th>
                        <th>Área Temática</th>
                        <th>Descripción</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% courses.forEach(course => { %>
                        <tr>
                            <td style="font-weight: 600;"><%= course.nombre %></td>
                            <td><%= course.duracion_horas %> h</td>
                            <td><%= course.area_tematica %></td>
                            <td><%= course.descripcion %></td>
                            <td>
                                <div style="display: flex; gap: 0.5rem;">
                                    <button class="btn" style="padding: 0.4rem; background: #f1f5f9; color: var(--primary);" onclick='editCourse(<%= JSON.stringify(course) %>)'>
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <a href="/courses/delete/<%= course.id_curso %>" class="btn" style="padding: 0.4rem; background: #f1f5f9; color: var(--error);" onclick="return confirm('¿Eliminar curso?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<!-- Modals -->
<div id="addModal" class="modal-overlay">
    <div class="modal-content">
        <h3>Registrar Curso</h3>
        <form action="/courses/add" method="POST">
            <div class="form-group">
                <label class="form-label">Nombre del Curso</label>
                <input type="text" name="nombre" class="form-control" required>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label class="form-label">Duración (Horas)</label>
                    <input type="number" name="duracion_horas" class="form-control" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Área Temática</label>
                    <input type="text" name="area_tematica" class="form-control" required>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Descripción</label>
                <textarea name="descripcion" class="form-control" rows="3"></textarea>
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
                <button type="button" class="btn" style="background: #e2e8f0;" onclick="closeModal('addModal')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Guardar Curso</button>
            </div>
        </form>
    </div>
</div>

<div id="editModal" class="modal-overlay">
    <div class="modal-content">
        <h3>Editar Curso</h3>
        <form id="editForm" action="" method="POST">
            <div class="form-group">
                <label class="form-label">Nombre del Curso</label>
                <input type="text" name="nombre" id="edit_nombre" class="form-control" required>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label class="form-label">Duración (Horas)</label>
                    <input type="number" name="duracion_horas" id="edit_duracion" class="form-control" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Área Temática</label>
                    <input type="text" name="area_tematica" id="edit_area" class="form-control" required>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Descripción</label>
                <textarea name="descripcion" id="edit_descripcion" class="form-control" rows="3"></textarea>
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
                <button type="button" class="btn" style="background: #e2e8f0;" onclick="closeModal('editModal')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Actualizar</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }
    function editCourse(course) {
        document.getElementById('editForm').action = '/courses/edit/' + course.id_curso;
        document.getElementById('edit_nombre').value = course.nombre;
        document.getElementById('edit_duracion').value = course.duracion_horas;
        document.getElementById('edit_area').value = course.area_tematica;
        document.getElementById('edit_descripcion').value = course.descripcion;
        openModal('editModal');
    }
</script>

<%- include('../partials/footer') %>
