<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main class="main-content">
    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="font-weight: 800; color: var(--secondary);">Calificaciones</h1>
            <p style="color: var(--text-muted);">Registro y seguimiento de notas por estudiante.</p>
        </div>
        <button class="btn btn-primary" onclick="openModal('addModal')">
            <i class="fas fa-plus" style="margin-right: 0.5rem;"></i> Registrar Nota
        </button>
    </header>

    <% if (error) { %>
        <div class="alert alert-error">
            <i class="fas fa-exclamation-triangle"></i> <%= error %>
        </div>
    <% } %>

    <div class="data-card" style="padding: 1.5rem; margin-top: 0; display: flex; align-items: center; gap: 1rem;">
        <i class="fas fa-filter" style="color: var(--text-muted);"></i>
        <form action="/grades" method="GET" style="display: flex; gap: 1rem; align-items: center; flex: 1;">
            <select name="group_id" class="form-control" style="max-width: 300px;">
                <option value="">Todos los grupos</option>
                <% groups.forEach(g => { %>
                    <option value="<%= g.id_grupo %>" <%= selectedGroup == g.id_grupo ? 'selected' : '' %>><%= g.nombre %></option>
                <% }) %>
            </select>
            <button type="submit" class="btn btn-primary" style="background: var(--secondary);">Filtrar</button>
            <a href="/grades" class="btn" style="background: #e2e8f0; color: var(--text-main);">Limpiar</a>
        </form>
    </div>

    <div class="data-card">
        <div class="table-header">
            <h3 style="font-size: 1.125rem;">Lista de Calificaciones</h3>
        </div>
        <div style="overflow-x: auto;">
            <table>
                <thead>
                    <tr>
                        <th>Estudiante</th>
                        <th>Curso</th>
                        <th>Módulo</th>
                        <th>Nota</th>
                        <th>Resultado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% grades.forEach(grade => { %>
                        <tr>
                            <td style="font-weight: 600;"><%= grade.student_nombres %> <%= grade.student_apellidos %></td>
                            <td><%= grade.curso_nombre %></td>
                            <td><%= grade.modulo %></td>
                            <td style="font-weight: 700; font-size: 1.1rem; color: <%= grade.nota >= 3.0 ? 'var(--success)' : 'var(--error)' %>;">
                                <%= grade.nota %>
                            </td>
                            <td>
                                <span style="font-weight: 600; color: <%= grade.nota >= 3.0 ? 'var(--success)' : 'var(--error)' %>;">
                                    <%= grade.nota >= 3.0 ? 'APROBADO' : 'REPROBADO' %>
                                </span>
                            </td>
                            <td>
                                <a href="/grades/delete/<%= grade.id_calificacion %>" class="btn" style="padding: 0.4rem; background: #f1f5f9; color: var(--error);" onclick="return confirm('¿Eliminar calificación?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<div id="addModal" class="modal-overlay">
    <div class="modal-content">
        <h3>Registrar Calificación</h3>
        <form action="/grades/add" method="POST">
            <div class="form-group">
                <label class="form-label">Seleccionar Estudiante Matriculado</label>
                <select name="id_matricula" class="form-control" required>
                    <% enrollments.forEach(en => { %>
                        <option value="<%= en.id_matricula %>"><%= en.student_nombres %> <%= en.student_apellidos %> - <%= en.curso_nombre %></option>
                    <% }) %>
                </select>
            </div>
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label class="form-label">Módulo</label>
                    <input type="text" name="modulo" class="form-control" placeholder="Ej: Fundamentos de JS" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Nota (0.0 - 5.0)</label>
                    <input type="number" step="0.1" min="0" max="5" name="nota" class="form-control" required>
                </div>
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
                <button type="button" class="btn" style="background: #e2e8f0;" onclick="closeModal('addModal')">Cancelar</button>
                <button type="submit" class="btn btn-primary">Guardar Nota</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }
</script>

<%- include('../partials/footer') %>
